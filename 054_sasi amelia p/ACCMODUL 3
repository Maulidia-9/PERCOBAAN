Import java.util.Scanner;

class Pegawai {
    protected String nama;
    protected int gajiPokok = 1000000;

    public Pegawai(String nama) {
        this.nama = nama;
    }

    public int hitungGaji() {
        return gajiPokok;
    }

    public void tampilGaji() {
        System.out.println("Nama: " + nama);
        System.out.println("Total Gaji: Rp " + hitungGaji());
    }
}

class Kasir extends Pegawai {
    private int hariHadir;

    public Kasir(String nama, int hariHadir) {
        super(nama);
        this.hariHadir = hariHadir;
    }

    public int hitungGaji() {
        return gajiPokok + (hariHadir * 5000);
    }
}

class Pramuniaga extends Pegawai {
    private int hariHadir;
    private int hariLembur;

    public Pramuniaga(String nama, int hariHadir, int hariLembur) {
        super(nama);
        this.hariHadir = hariHadir;
        this.hariLembur = hariLembur;
    }

    public int hitungGaji() {
        return gajiPokok + (hariHadir * 5000) + (hariLembur * 20000);
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.print("Masukkan nama kasir: ");
        String namaKasir = input.nextLine();
        System.out.print("Masukkan hari hadir kasir: ");
        int hadirKasir = input.nextInt();

        Pegawai p1 = new Kasir(namaKasir, hadirKasir);

        input.nextLine();

        System.out.print("Masukkan nama pramuniaga: ");
        String namaPramuniaga = input.nextLine();
        System.out.print("Masukkan hari hadir: ");
        int hadirPramuniaga = input.nextInt();
        System.out.print("Masukkan hari lembur: ");
        int lembur = input.nextInt();

        Pegawai p2 = new Pramuniaga(namaPramuniaga, hadirPramuniaga, lembur);

        System.out.println("\n=== Data Gaji ===");
        p1.tampilGaji();
        System.out.println();
        p2.tampilGaji();
    }
}
