import java.util.Scanner;

// Class
class Trapesium {
  // Atribut
  double sisiAtas;
  double sisiBawah;
  double tinggiTrapesium;
  double tinggiPrisma;
  // Method untuk menghitung luas trapesium double hitungLuas() {

  return 0.5 * (sisiAtas + sisiBawah) * tinggiTrapesium;
}

// Method untuk menghitung volume
double hitungVolume() {
  return hitungLuas() * tinggiPrisma;
  }
}

public class accmodull1 {
  public static void main(String[] args) {
    Scanner input = new Scanner(System.in);

  // Membuat objek
  Trapesium tp = new Trapesium();

  // Input user
  System.out.print("Masukkan panjang sisi atas: ");
  tp.sisiAtas = input.nextDouble();

  System.out.print("Masukkan panjang sisi bawah: ");
  tp.sisiBawah = input.nextDouble();

  System.out.print("Masukkan tinggi trapesium: ");
  tp.tinggiTrapesium = input.nextDouble();

  System.out.print("Masukkan tinggi prisma: ");
  tp.tinggiPrisma = input.nextDouble();

  // Output
  System.out.println("Luas Trapesium = " + tp.hitungLuas());
  }
}
}
System.out.println("Volume Trapesium = " + tp.hitungVolume());
}
}
