public class Kucing extends Hewan implements Perawatan {

    public Kucing(String nama, int umur) {
        super(nama, umur, 150000);
    }

    @Override
    public void tampilkanInfo() {
        System.out.println("\n===== DATA HEWAN =====");
        System.out.println("Jenis Hewan : Kucing");
        System.out.println("Nama Hewan  : " + getNama());
        System.out.println("Umur Hewan  : " + umur + " Tahun");
        System.out.println("Biaya Adopsi: Rp" + (int) biayaAdopsi);
        System.out.println("Fasilitas:");
        System.out.println("- Vaksin Dasar");
        System.out.println("- Grooming");
        System.out.println("- Buku Kesehatan");
    }

    @Override
    public void jadwalPerawatan() {
        System.out.println("Perawatan   : Vaksin dan Grooming");
    }
}
