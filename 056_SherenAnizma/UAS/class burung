public class Burung extends Hewan implements Perawatan {

    public Burung(String nama, int umur) {
        super(nama, umur,100000);
    }

    @Override
    public void tampilkanInfo() {
        System.out.println("\n===== DATA HEWAN =====");
        System.out.println("Jenis Hewan : Burung");
        System.out.println("Nama Hewan  : " + getNama());
        System.out.println("Umur Hewan  : " + umur + " Tahun");
        System.out.println("Biaya Adopsi: Rp" + (int) biayaAdopsi);
        System.out.println("Fasilitas:");
        System.out.println("- Vitamin");
        System.out.println("- Pembersihan Kandang");
    }

    @Override
    public void jadwalPerawatan() {
        System.out.println("Perawatan   : Pembersihan Kandang");
    }
}
