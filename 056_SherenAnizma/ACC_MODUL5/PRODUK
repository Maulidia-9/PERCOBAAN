package produk; 
 
public class Produk { 
 
    public String namaProduk; 
    protected int harga; 
    private int stok; 
 
    public Produk(String namaProduk, int harga, int stok) { 
        this.namaProduk = namaProduk; 
        this.harga = harga; 
        this.stok = stok; 
    } 
 
    public int getHarga() { 
        return harga; 
    } 
 
    public int getStok() { 
        return stok; 
    } 
 
    public void tampilProduk() { 
        System.out.println("Produk : " + namaProduk); 
        System.out.println("Harga  : " + harga); 
        System.out.println("Stok   : " + stok); 
    }
