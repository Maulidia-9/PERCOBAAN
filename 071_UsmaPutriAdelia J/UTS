import java.util.*;

class Siswa {
String nama, nis;

Siswa(String nama, String nis) { // constructor
this.nama = nama;
this.nis = nis;
}
}

// SUPER CLASSadmin
abstract class Transaksi {
int admin = 5000;
abstract int hitungTotal(); // polymorphism (method abstract)
abstract void tampil(Siswa s);
}

// SUBCLASS SPP
class SPP extends Transaksi {
String bulan;
int pokok, tgl, denda;
this.tgl = tgl;
}

int hitungTotal() { // override
denda = (tgl > 10) ? 15000 : 0;
return pokok + admin + denda;
}

void tampil(Siswa s) {

System.out.println("\n===[SPP]===");
System.out.println(s.nama + " | " + s.nis);
System.out.println("Bulan : " + bulan);
System.out.println("Pokok : " + pokok);
System.out.println("Denda : " + denda);
System.out.println("Admin : " + admin );
System.out.println("Total : " + hitungTotal());
}
}

// SUBCLASS SERAGAM
class Seragam extends Transaksi {
String ukuran;
int dasar, tambahan;

Seragam(String ukuran, int dasar) { // constructor
this.ukuran = ukuran;
this.dasar = dasar;
}

int hitungTotal() { // override
tambahan = ukuran.equalsIgnoreCase("XL") ? 20000 : 0 ;
return dasar + admin + tambahan;
SPP(String bulan, int pokok, int tgl) { // constructor
this.bulan = bulan;
this.pokok = pokok;
}

void tampil(Siswa s) {
System.out.println("\n===[SERAGAM]===");
System.out.println(s.nama + " | " + s.nis);
System.out.println("Ukuran : " + ukuran);
System.out.println("Dasar : " + dasar);
System.out.println("Tambahan : " + tambahan);
System.out.println("Admin : " + admin);
System.out.println("Total : " + hitungTotal());
}
}

