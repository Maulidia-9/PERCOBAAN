package model;

public class Buku {
    protected String judul;
    protected String penulis;

    // Constructor
    public Buku(String judul, String penulis) {
        this.judul = judul;
        this.penulis = penulis;
    }

    public void tampilInfo() {
        System.out.println("Judul   : " + judul);
        System.out.println("Penulis : " + penulis);
    }
}
package model;

public class Ebook extends Buku {
    private double ukuranFile;

    
    public Ebook(String judul, String penulis, double ukuranFile) {
        super(judul, penulis);
        this.ukuranFile = ukuranFile;
    }

    public void tampilInfo() {
        super.tampilInfo();
        System.out.println("Ukuran File : " + ukuranFile + " MB");
    }
}
package service;

import model.Buku;
import model.Ebook;

public class KelolaBuku {

    public void tampilBuku(Buku buku) {
        buku.tampilInfo();
        System.out.println("---------------------");
    }

    public void tampilEbook(Ebook ebook) {
        ebook.tampilInfo();
        System.out.println("---------------------");
    }
}
package main;

import model.Buku;
import model.Ebook;
import service.KelolaBuku;

public class Main {
    public static void main(String[] args) {

        // Membuat object menggunakan constructor
        Buku buku1 = new Buku(
                "bulan",
                "tereliye");

        Ebook ebook1 = new Ebook(
                "matahari",
                "tereliye",
                15.5);

        KelolaBuku kelola = new KelolaBuku();

        kelola.tampilBuku(buku1);
        kelola.tampilEbook(ebook1);
    }
}
