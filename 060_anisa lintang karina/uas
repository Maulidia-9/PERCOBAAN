//CLASINDUK
//abstracsion; tidak bisa membuat object secara langsung dikode hewan nya jadi bwrfungsi dengan clas induk
//modivaier kita menggunakan
public abstract class Hewan { //bisa di akses
    private String nama; // hanya kelas itu saja yg bisa akses
    protected int umur; //bisa di akses oleh pacage yg sama dan turunan nya
    protected double biayaAdopsi;

//CONSTRUCTOR
    public Hewan(String nama, int umur, double biayaAdopsi) {
        this.nama = nama;
        this.umur = umur;
        this.biayaAdopsi = biayaAdopsi;
    }

    public String getNama() {
        return nama;
    }
    
    public abstract void tampilkanInfo();
}
//WARISAN DR HEWAN
//implements perawatan 
public class Kucing extends Hewan implements Perawatan {

//CONSTRUCTOR
    public Kucing(String nama, int umur) {
        super(nama, umur,15000);
    }

    @Override 
    public void tampilkanInfo() {
        System.out.println("\n===== DATA HEWAN =====");
        System.out.println("Jenis Hewan : Kucing");
        System.out.println("Nama Hewan  : " + getNama());
        System.out.println("Umur Hewan  : " + umur + " Tahun");
        System.out.println("Biaya Adopsi: Rp" + (int) biayaAdopsi);
        System.out.println("Fasilitas:");
        System.out.println("- Vaksin Dasar");
        System.out.println("- Grooming");
        System.out.println("- Buku Kesehatan");
    }

    @Override
    public void jadwalPerawatan() {
        System.out.println("Perawatan   : Vaksin dan Grooming");
    }
}
